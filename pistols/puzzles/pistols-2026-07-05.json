  "protocol": [
    {
      "id": "partners_left",
      "text": "Business partners sit to the host's left unless under litigation.",
      "restate": true
    },
    {
      "id": "bishop_clause",
      "text": "No lady is seated at the elbow of a guest with a loaded pistol unless she is widowed, titled, or has previously shot a bishop.",
      "restate": true
    },
    {
      "id": "kin_same_side",
      "text": "Kin are seated upon the same side of the table, elder nearer the host.",
      "restate": true
    },
    {
      "id": "quarrel_salt",
      "text": "A guest who has quarrelled with the host is seated \"below the salt\" (the seats nearest the foot).",
      "restate": true
    },
    {
      "id": "memorial_pistol",
      "text": "The pistol at an empty place is laid, but never loaded.",
      "restate": true
    },
    {
      "id": "host_pistol",
      "text": "The host's own pistol is always charged — a fixture of the table, and no threat to those who sit beside it.",
      "restate": true
